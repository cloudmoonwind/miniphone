  },
  {
    "id": "tl_ysl_002",
    "charId": "char_1773377502265_2f2r",
    "title": "旧书店的偶遇",
    "content": "在二手书店翻到一本绝版的推理小说，正要结账时发现那个人也在。装作没看见，但心跳快了半拍。",
    "type": "event",
    "timestamp": "2026-02-20T14:20:00.000Z",
    "linkedItemIds": [
      "item_ysl_002"
