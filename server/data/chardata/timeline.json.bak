[
  {
    "id": "tl_ysl_001",
    "charId": "char_1773377502265_2f2r",
    "title": "午夜的屋顶",
    "content": "独自坐在天台上，城市的灯光倒映在瞳孔里。风很大，但他没有要走的意思。这是他第一次对某个人说了'再见'之后感到不安。",
    "type": "milestone",
    "timestamp": "2026-02-15T23:30:00.000Z",
