  },
  {
    "id": "tl_ysl_003",
    "charId": "char_1773377502265_2f2r",
    "title": "第一次主动发消息",
    "content": "盯着聊天界面看了十分钟，最后发了一句'那本书你看完了吗'。发完就把手机扣在桌上不敢看。",
    "type": "chat",
    "timestamp": "2026-02-25T21:45:00.000Z",
