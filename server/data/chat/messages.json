    "personaId": null,
    "sender": "user",
    "content": "嗯，没事了，你早点睡",
    "mode": "online",
    "timestamp": "2026-03-21T17:36:52.755Z",
    "userTimestamp": "2026-03-21T17:36:52.755Z",
